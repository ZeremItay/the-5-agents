# =============================================================================
# TESTTOMORROW — Environment Variables Template
# =============================================================================
# העתק את הקובץ הזה ל-`.env` ומלא את הערכים האמיתיים.
# Copy this file to `.env` and fill in real values.
# הקובץ `.env` מוסתר ב-.gitignore ולא יעלה ל-GitHub.
# =============================================================================

# --- Anthropic / Claude API ---
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Default model for agents (optional — defaults to latest if unset)
# Examples: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=

# --- Project ---
# Logging level: debug | info | warn | error
LOG_LEVEL=info
